generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  //DO NOT UPDATE PRISMA TO VERSION 7 KEEP IT AS VERSION 6 
  //IT OVERCOMPLICATES IT FOR US FOR NO REASON
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(READ_ONLY)
  createdAt    DateTime @default(now())

  campaigns Campaign[]
}

model Campaign {
  id          Int            @id @default(autoincrement())
  name        String
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  createdAt   DateTime       @default(now())

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id])

  targets Target[]
  events  Event[]
}

model Target {
  id         Int     @id @default(autoincrement())
  email      String
  department String?
  token      String  @unique

  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  events Event[]
}

model Event {
  id        Int       @id @default(autoincrement())
  type      EventType
  createdAt DateTime  @default(now())

  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  targetId Int
  target   Target @relation(fields: [targetId], references: [id])
}

enum Role {
  ADMIN
  READ_ONLY
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
}

enum EventType {
  OPEN
  CLICK
  SUBMIT
}
